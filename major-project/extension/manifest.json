{
  "manifest_version": 3,
  "name": "Cognitive Form Assist",
  "version": "1.0.0",
  "description": "Simplified, contextual help for web form fields (AI-powered optional).",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}

{
  "manifest_version": 3,
  "name": "Cognitive Form Assist",
  "version": "1.0.0",
  "description": "Simplified, contextual help for web form fields (AI-powered optional).",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cognitive Form Assist"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["metrics.js", "voice-hi.js", "voice-kn.js", "content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
